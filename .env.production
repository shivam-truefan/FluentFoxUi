# Production Environment Variables
# Used for the production build/deploy (e.g. Render).
# Vite ONLY exposes variables prefixed with VITE_ to the browser.
# (Do not set NODE_ENV here — Vite manages it and warns if overridden.)

# Backend API base URL, no trailing slash — UPDATE with your real backend URL.
# Read by src/api/client.ts via import.meta.env.VITE_API_URL.
VITE_API_URL=https://your-backend-api-url.com
